# ===========================================
# FGEHA RCP Backend — Environment variables
# ===========================================
# Copy this file to .env (in this folder or in src/) and set values.
# Do not commit .env — it is in .gitignore.

# -------------------------------------------
# Server
# -------------------------------------------
# Port the API listens on. Use 8080 so admin and mobile app can use http://...:8080
PORT=8080

# -------------------------------------------
# Database (MySQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=fgeha_rcp

# -------------------------------------------
# JWT (auth tokens)
# -------------------------------------------
# Use a long random string in production (e.g. openssl rand -base64 32)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# -------------------------------------------
# First admin user (created on startup if no admin exists)
# -------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!

# -------------------------------------------
# Email verification (optional but recommended)
# -------------------------------------------
# Base URL for verification links (e.g. https://api.yourdomain.com). Used in emails.
APP_URL=http://localhost:8080
# Gmail SMTP — use an App Password, not your normal password:
# https://myaccount.google.com/apppasswords (requires 2-Step Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=your.email@gmail.com

# -------------------------------------------
# Sentry (optional – error monitoring)
# -------------------------------------------
# Set DSN to enable. Remove the line or leave empty to disable – app runs normally, no errors.
# In production, prefer injecting SENTRY_DSN via server env (Docker, PM2, etc.), not from .env in repo.
# Create a project at https://sentry.io and paste the DSN. Do not use quotes around the value.
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DEBUG=true              # optional; enables Sentry SDK logs in console (for troubleshooting)
# SENTRY_TRACES_SAMPLE_RATE=0.05  # optional; default 0.05 in prod, 1.0 in dev (e.g. 0.05 = 5% of traces)
# APP_VERSION=1.0.0               # optional; set for release tracking and source map matching (e.g. git rev-parse --short HEAD)

# -------------------------------------------
# Optional
# -------------------------------------------
# NODE_ENV=development
APP_MINIMUM_VERSION=1.0.3
APP_LATEST_VERSION=1.0.3
APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.fgeha.app